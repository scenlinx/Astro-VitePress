---
import MainLayout from '../layouts/MainLayout.astro';
import { navConfig } from '../config/site';

export async function getStaticPaths() {
  const docs = Object.entries(import.meta.glob('/docs/**/*.md', { eager: true }));
  return docs
    .filter(([p]) => {
      const slug = p.replace('/docs/', '').replace(/\.md$/, '').replace(/\/index$/, '');
      return slug !== 'index';
    })
    .map(([path, mod]) => {
      const slug = path.replace('/docs/', '').replace(/\.md$/, '').replace(/\/index$/, '');
      return { params: { slug }, props: { mod } };
    });
}

const { mod } = Astro.props;
const { Content, frontmatter } = mod;
const segments = Astro.params.slug.split('/');
const currentFolder = segments[0];

const allDocs = Object.entries(import.meta.glob('/docs/**/*.md', { eager: true }));
const cleanSlug = p => p.replace('/docs/', '').replace(/\.md$/, '').replace(/\/index$/, '');

const navItems = navConfig.map(item => {
  if (item.type === 'folder') {
    const pages = allDocs.filter(([p]) => p.startsWith(`/docs/${item.id}/`));
    const first = pages.sort((a, b) => (a[1].frontmatter?.order ?? 999) - (b[1].frontmatter?.order ?? 999))[0];
    return { text: item.text, link: `/${cleanSlug(first?.[0] || '')}` };
  }
  return { text: item.text, link: item.id === '/' ? '/' : `/${item.id}` };
});

const currentNav = navConfig.find(item =>
  item.type === 'folder' ? item.id === currentFolder : item.id === currentFolder
);

const toSidebar = (p, m) => ({ text: m.frontmatter?.title || '', link: `/${cleanSlug(p)}`, order: m.frontmatter?.order ?? 999 });
const sortSidebar = (a, b) => a.order - b.order;

const sidebarItems = currentNav?.type === 'folder'
  ? allDocs
      .filter(([p]) => p.startsWith(`/docs/${currentFolder}/`))
      .map(([p, m]) => toSidebar(p, m))
      .sort(sortSidebar)
  : allDocs
      .filter(([p]) => p.split('/')[2].indexOf('.') !== -1 && !p.endsWith('/index.md'))
      .map(([p, m]) => toSidebar(p, m))
      .sort(sortSidebar);

const allPages = [];
navConfig.forEach(item => {
  if (item.type === 'folder') {
    const pages = allDocs
      .filter(([p]) => p.startsWith(`/docs/${item.id}/`))
      .map(([p, m]) => toSidebar(p, m))
      .sort(sortSidebar);
    allPages.push(...pages);
  } else if (item.type === 'page' && item.id !== '/') {
    const pages = allDocs
      .filter(([p]) => p.replace('/docs/', '').replace(/\.md$/, '') === item.id)
      .map(([p, m]) => toSidebar(p, m));
    allPages.push(...pages);
  }
});

const currentIdx = allPages.findIndex(item => item.link === Astro.url.pathname.replace(/\/$/, ''));
const prev = currentIdx > 0 ? allPages[currentIdx - 1] : null;
const next = currentIdx < allPages.length - 1 ? allPages[currentIdx + 1] : null;
---

<MainLayout title={frontmatter.title} frontmatter={frontmatter} navItems={navItems} sidebarItems={sidebarItems} prev={prev} next={next}>
  <Content />
</MainLayout>
