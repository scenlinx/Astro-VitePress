---
import MainLayout from '../layouts/MainLayout.astro';
import { folderNames, folderOrder } from '../config/site';

export async function getStaticPaths() {
  const docs = Object.entries(import.meta.glob('/docs/**/*.md', { eager: true }));
  return docs
    .filter(([p]) => {
      const slug = p.replace('/docs/', '').replace(/\.md$/, '').replace(/\/index$/, '');
      return slug !== 'index';
    })
    .map(([path, mod]) => {
      const slug = path.replace('/docs/', '').replace(/\.md$/, '').replace(/\/index$/, '');
      return { params: { slug }, props: { mod } };
    });
}

const { mod } = Astro.props;
const { Content, frontmatter } = mod;
const segments = Astro.params.slug.split('/');
const currentFolder = segments[0];

const allDocs = Object.entries(import.meta.glob('/docs/**/*.md', { eager: true }));
const cleanSlug = p => p.replace('/docs/', '').replace(/\.md$/, '').replace(/\/index$/, '');

const isFolder = name => allDocs.some(([p]) => p.startsWith(`/docs/${name}/`));
const folders = [...new Set(allDocs.map(([p]) => {
  const seg = p.split('/')[2];
  return seg.indexOf('.') === -1 ? seg : null;
}).filter(Boolean))].sort((a, b) => (folderOrder[a] || 99) - (folderOrder[b] || 99));

const folderNav = folders.map(f => {
  const first = allDocs.find(([p]) => p.startsWith(`/docs/${f}/`));
  return { text: folderNames[f] || f, link: `/${cleanSlug(first[0])}` };
});

const pageNav = allDocs.filter(([p]) => p.split('/')[2].indexOf('.') !== -1 && !p.endsWith('/index.md'))
  .map(([p, m]) => ({ text: m.frontmatter?.title || '', link: `/${cleanSlug(p)}` }));

const navItems = [...folderNav, ...pageNav];

const sidebarItems = isFolder(currentFolder)
  ? allDocs
      .filter(([p]) => p.startsWith(`/docs/${currentFolder}/`))
      .map(([p, m]) => ({ text: m.frontmatter?.title || '', link: `/${cleanSlug(p)}` }))
  : allDocs
      .filter(([p]) => p.split('/')[2].indexOf('.') !== -1 && !p.endsWith('/index.md'))
      .map(([p, m]) => ({ text: m.frontmatter?.title || '', link: `/${cleanSlug(p)}` }));
---

<MainLayout title={frontmatter.title} frontmatter={frontmatter} navItems={navItems} sidebarItems={sidebarItems}>
  <Content />
</MainLayout>
