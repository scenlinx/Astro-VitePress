---
import MainLayout from '../layouts/MainLayout.astro';
import { navConfig } from '../config/site';
import { loadAllDocsMeta, buildNavItems, buildAllPages, buildSidebarItems } from '../config/docs';

export async function getStaticPaths() {
  const { allMeta, modules } = await loadAllDocsMeta();
  return allMeta
    .filter(m => m.slug !== 'index')
    .map(m => ({ params: { slug: m.slug }, props: { mod: modules[m.path], allMeta } }));
}

const { mod, allMeta } = Astro.props;
const { Content, frontmatter } = mod;
const segments = Astro.params.slug.split('/');
const currentFolder = segments[0];

const navItems = buildNavItems(allMeta);
const sidebarItems = buildSidebarItems(allMeta, currentFolder);
const allPages = buildAllPages(allMeta);
const currentIdx = allPages.findIndex(item => item.link === Astro.url.pathname.replace(/\/$/, ''));
const prev = currentIdx > 0 ? allPages[currentIdx - 1] : null;
const next = currentIdx < allPages.length - 1 ? allPages[currentIdx + 1] : null;
const curNav = navConfig.find(n => n.id === currentFolder);
const currentSection = curNav?.type === 'folder' ? curNav.text : frontmatter?.title;
---

<MainLayout title={frontmatter.title} frontmatter={frontmatter} navItems={navItems} sidebarItems={sidebarItems} prev={prev} next={next} slug={Astro.params.slug} currentSection={currentSection}>
  <Content />
</MainLayout>
