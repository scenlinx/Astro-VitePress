---
import MainLayout from '../layouts/MainLayout.astro';
import { folderNames, folderOrder } from '../config/site';

export async function getStaticPaths() {
  const docs = Object.entries(import.meta.glob('/docs/**/*.md', { eager: true }));
  return docs.map(([path, mod]) => {
    const slug = path.replace('/docs/', '').replace(/\.md$/, '');
    return { params: { slug }, props: { mod } };
  });
}

const { mod } = Astro.props;
const { Content, frontmatter } = mod;
const segments = Astro.params.slug.split('/');
const currentFolder = segments[0];

const allDocs = Object.entries(import.meta.glob('/docs/**/*.md', { eager: true }));
const folders = [...new Set(allDocs.map(([p]) => p.split('/')[2]))].sort((a, b) => (folderOrder[a] || 99) - (folderOrder[b] || 99));
const navItems = folders.map(f => {
  const first = allDocs.find(([p]) => p.startsWith(`/docs/${f}/`));
  const slug = first[0].replace('/docs/', '').replace(/\.md$/, '');
  return { text: folderNames[f] || f, link: `/${slug}` };
});

const sidebarItems = allDocs
  .filter(([p]) => p.startsWith(`/docs/${currentFolder}/`))
  .map(([p, m]) => {
    const slug = p.replace('/docs/', '').replace(/\.md$/, '');
    return { text: m.frontmatter?.title || '', link: `/${slug}` };
  });
---

<MainLayout title={frontmatter.title} frontmatter={frontmatter} navItems={navItems} sidebarItems={sidebarItems}>
  <Content />
</MainLayout>
