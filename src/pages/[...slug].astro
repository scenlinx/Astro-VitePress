---
import MainLayout from '../layouts/MainLayout.astro';
import { navConfig } from '../config/site';

export async function getStaticPaths() {
  const cleanSlug = p => p.replace('/docs/', '').replace(/\.md$/, '').replace(/\/index$/, '');
  const docsGlob = import.meta.glob('/docs/**/*.md');
  const entries = Object.entries(docsGlob);
  const allMeta = [];
  const results = [];

  for (const [path, loader] of entries) {
    const mod = await loader();
    const slug = cleanSlug(path);
    allMeta.push({ path, slug, frontmatter: mod.frontmatter });
    if (slug !== 'index') {
      results.push({ params: { slug }, props: { mod, allMeta } });
    }
  }
  return results;
}

const cleanSlug = p => p.replace('/docs/', '').replace(/\.md$/, '').replace(/\/index$/, '');
const { mod, allMeta } = Astro.props;
const { Content, frontmatter } = mod;
const segments = Astro.params.slug.split('/');
const currentFolder = segments[0];

const navItems = navConfig.map(item => {
  if (item.type === 'folder') {
    const pages = allMeta.filter(m => m.path.startsWith(`/docs/${item.id}/`));
    const first = pages.sort((a, b) => (a.frontmatter?.order ?? 999) - (b.frontmatter?.order ?? 999))[0];
    return { text: item.text, link: `/${cleanSlug(first?.path || '')}` };
  }
  return { text: item.text, link: item.id === '/' ? '/' : `/${item.id}` };
});

const currentNav = navConfig.find(item =>
  item.type === 'folder' ? item.id === currentFolder : item.id === currentFolder
);

const toSidebar = m => ({
  text: m.frontmatter?.title || '',
  link: `/${m.slug}`,
  order: m.frontmatter?.order ?? 999
});
const sortSidebar = (a, b) => a.order - b.order;

const sidebarItems = currentNav?.type === 'folder'
  ? allMeta
      .filter(m => m.path.startsWith(`/docs/${currentFolder}/`))
      .map(toSidebar)
      .sort(sortSidebar)
  : allMeta
      .filter(m => m.path.split('/')[2]?.indexOf('.') !== -1 && !m.path.endsWith('/index.md'))
      .map(toSidebar)
      .sort(sortSidebar);

const allPages = [];
navConfig.forEach(item => {
  if (item.type === 'folder') {
    const pages = allMeta
      .filter(m => m.path.startsWith(`/docs/${item.id}/`))
      .map(toSidebar)
      .sort(sortSidebar);
    allPages.push(...pages);
  } else if (item.type === 'page' && item.id !== '/') {
    const pages = allMeta
      .filter(m => m.slug === item.id)
      .map(toSidebar);
    allPages.push(...pages);
  }
});

const currentIdx = allPages.findIndex(item => item.link === Astro.url.pathname.replace(/\/$/, ''));
const prev = currentIdx > 0 ? allPages[currentIdx - 1] : null;
const next = currentIdx < allPages.length - 1 ? allPages[currentIdx + 1] : null;
---

<MainLayout title={frontmatter.title} frontmatter={frontmatter} navItems={navItems} sidebarItems={sidebarItems} prev={prev} next={next}>
  <Content />
</MainLayout>
