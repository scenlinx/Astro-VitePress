---
import HomeLayout from '../layouts/HomeLayout.astro';
import { folderNames, folderOrder } from '../config/site';

const allDocs = Object.entries(import.meta.glob('/docs/**/*.md', { eager: true }));
const folders = [...new Set(allDocs.map(([p]) => p.split('/')[2]))].sort((a, b) => (folderOrder[a] || 99) - (folderOrder[b] || 99));
const navItems = folders.map(f => {
  const first = allDocs.find(([p]) => p.startsWith(`/docs/${f}/`));
  const slug = first[0].replace('/docs/', '').replace(/\.md$/, '');
  return { text: folderNames[f] || f, link: `/${slug}` };
});
---

<HomeLayout 
  title="VitePress" 
  navItems={navItems}
>
  <div class="home">
    <div class="hero">
      <div class="logo">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h1>VitePress</h1>
      <p>Vue 驱动的静态网站生成器</p>
      <div class="actions">
        <a href={navItems.find(n => n.text === '指南')?.link || '/guide/quickstart'} class="btn primary">快速开始</a>
        <a href="https://github.com/vuejs/vitepress" target="_blank" class="btn">在 GitHub 上查看</a>
      </div>
    </div>
    
    <div class="features">
      <div class="feature">
        <h3>基于 Vite</h3>
        <p>闪电般快速的热更新，无论项目大小始终保持快速。</p>
      </div>
      <div class="feature">
        <h3>Vue 驱动</h3>
        <p>享受 Vue 3 模板语法和组合式 API 的全部能力。</p>
      </div>
      <div class="feature">
        <h3>Markdown 优先</h3>
        <p>专注于内容，内置支持 Vue 组件的 Markdown 扩展。</p>
      </div>
    </div>
  </div>
</HomeLayout>
