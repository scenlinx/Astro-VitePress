---
import HomeLayout from '../layouts/HomeLayout.astro';
import { loadAllDocsMeta, buildNavItems } from '../config/docs';

const { allMeta } = await loadAllDocsMeta();
const navItems = buildNavItems(allMeta);
const homeEntry = allMeta.find(m => m.slug === 'index');
const homeFm = homeEntry?.frontmatter || {};
---

<HomeLayout 
  title={homeFm.title || 'Astro-VitePress'} 
  navItems={navItems}
>
  <div class="home">
    <div class="hero">
      <div class="logo">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h1>{homeFm.heroTitle}</h1>
      <p>{homeFm.heroDesc}</p>
      <div class="actions">
        <a href={homeFm.primaryActionLink || '/guide/quickstart'} class="btn primary">{homeFm.primaryAction}</a>
        <a href={homeFm.secondaryActionLink || '#'} target="_blank" class="btn">{homeFm.secondaryAction}</a>
      </div>
    </div>
    
    <div class="features">
      {homeFm.features?.map(f => (
        <div class="feature">
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</HomeLayout>
