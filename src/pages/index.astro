---
import HomeLayout from '../layouts/HomeLayout.astro';
import { folderNames, folderOrder } from '../config/site';

const allDocs = Object.entries(import.meta.glob('/docs/**/*.md', { eager: true }));
const cleanSlug = p => p.replace('/docs/', '').replace(/\.md$/, '').replace(/\/index$/, '');

const folders = [...new Set(allDocs.map(([p]) => {
  const seg = p.split('/')[2];
  return seg.indexOf('.') === -1 ? seg : null;
}).filter(Boolean))].sort((a, b) => (folderOrder[a] || 99) - (folderOrder[b] || 99));

const folderNav = folders.map(f => {
  const first = allDocs.find(([p]) => p.startsWith(`/docs/${f}/`));
  return { text: folderNames[f] || f, link: `/${cleanSlug(first[0])}` };
});

const pageNav = allDocs.filter(([p]) => p.split('/')[2].indexOf('.') !== -1 && !p.endsWith('/index.md'))
  .map(([p, m]) => ({ text: m.frontmatter?.title || '', link: `/${cleanSlug(p)}` }));

const navItems = [...folderNav, ...pageNav];

const homeEntry = allDocs.find(([p]) => p === '/docs/index.md');
const { frontmatter: homeFm } = homeEntry[1];
---

<HomeLayout 
  title={homeFm.title || 'VitePress'} 
  navItems={navItems}
>
  <div class="home">
    <div class="hero">
      <div class="logo">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h1>{homeFm.heroTitle}</h1>
      <p>{homeFm.heroDesc}</p>
      <div class="actions">
        <a href={homeFm.primaryActionLink || '/guide/quickstart'} class="btn primary">{homeFm.primaryAction}</a>
        <a href={homeFm.secondaryActionLink || '#'} target="_blank" class="btn">{homeFm.secondaryAction}</a>
      </div>
    </div>
    
    <div class="features">
      {homeFm.features?.map(f => (
        <div class="feature">
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</HomeLayout>
