---
import MainLayout from '../layouts/MainLayout.astro';
import { loadAllDocsMeta, buildNavItems } from '../config/docs';

const { allMeta } = await loadAllDocsMeta();
const navItems = buildNavItems(allMeta);
---

<MainLayout title="页面未找到" navItems={navItems}>
  <div class="not-found">
    <h1>404</h1>
    <p>您访问的页面不存在。</p>
    <a href="/" class="btn primary">返回首页</a>
  </div>
</MainLayout>

<style>
  .not-found {
    text-align: center;
    padding: 80px 0;
  }
  .not-found h1 {
    font-size: 72px;
    margin-bottom: 16px;
    background: var(--gradient-brand);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .not-found p {
    font-size: var(--font-size-xl);
    color: var(--text-color-light);
    margin-bottom: 32px;
  }
</style>
