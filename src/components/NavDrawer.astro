---
// NavDrawer.astro — 移动端导航抽屉组件
import GitHubIcon from './icons/GitHubIcon.astro';
import SunIcon from './icons/SunIcon.astro';
import { siteConfig } from '../config/site';

export interface Props {
  navItems: { text: string; link: string }[];
  currentPath: string;
}

const { navItems, currentPath } = Astro.props;
---

<div class="nav-drawer">
  {navItems.map(item => (
    <a href={item.link} class={`nav-link ${currentPath === item.link ? 'active' : ''}`} aria-current={currentPath === item.link ? 'page' : undefined}>{item.text}</a>
  ))}
  <div class="nav-drawer-actions">
    <a href={siteConfig.github} class="nav-gh-link" target="_blank" rel="noopener">
      <GitHubIcon />GitHub
    </a>
    <button class="drawer-theme-toggle" aria-label="Toggle theme">
      <SunIcon />
      切换主题
    </button>
  </div>
</div>

<script>
  const hamburgerNav = document.querySelector('.hamburger-nav');
  const navDrawer = document.querySelector('.nav-drawer');
  const sidebarOverlay = document.querySelector('.sidebar-overlay');
  hamburgerNav?.addEventListener('click', () => {
    navDrawer?.classList.toggle('open');
    sidebarOverlay?.classList.toggle('open', navDrawer?.classList.contains('open'));
  });
  sidebarOverlay?.addEventListener('click', () => {
    navDrawer?.classList.remove('open');
    sidebarOverlay?.classList.remove('open');
  });
</script>
