---
// FloatingButtons.astro — 浮动按钮组件（搜索按钮 + 返回顶部按钮）
import SearchIcon from './icons/SearchIcon.astro';

export interface Props {
  showBackToTop?: boolean;
}

const { showBackToTop = false } = Astro.props;
---

<!-- Floating search button -->
<button class="search-btn-floating" id="searchBtnFloating" aria-label="Search">
  <SearchIcon />
</button>

{showBackToTop && (
  <button class="back-to-top" aria-label="Back to top">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="12" y1="19" x2="12" y2="5"/>
      <polyline points="5 12 12 5 19 12"/>
    </svg>
  </button>
)}

<script>
  const searchBtnFloating = document.getElementById('searchBtnFloating');
  const backToTop = document.querySelector('.back-to-top');

  searchBtnFloating?.addEventListener('click', () => {
    (window as any).__openSearch?.();
  });

  let floatingTicking = false;
  window.addEventListener('scroll', () => {
    if (!floatingTicking) {
      requestAnimationFrame(() => {
        const show = window.scrollY > 300;
        searchBtnFloating?.classList.toggle('visible', show);
        backToTop?.classList.toggle('visible', show);
        floatingTicking = false;
      });
      floatingTicking = true;
    }
  }, { passive: true });

  backToTop?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>
