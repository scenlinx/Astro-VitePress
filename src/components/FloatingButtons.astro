---
// FloatingButtons.astro — 浮动按钮组件（搜索按钮 + 返回顶部按钮）
import SearchIcon from './icons/SearchIcon.astro';

export interface Props {
  showBackToTop?: boolean;
}

const { showBackToTop = false } = Astro.props;
---

<!-- Floating search button -->
<button class="search-btn-floating" id="searchBtnFloating" aria-label="Search">
  <SearchIcon />
</button>

{showBackToTop && (
  <button class="back-to-top" aria-label="Back to top">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <line x1="12" y1="19" x2="12" y2="5"/>
      <polyline points="5 12 12 5 19 12"/>
    </svg>
  </button>
)}

<script>
  var searchBtnFloating = document.getElementById('searchBtnFloating');
  var backToTop = document.querySelector('.back-to-top');

  if (searchBtnFloating) {
    searchBtnFloating.addEventListener('click', function() {
      if (window.__openSearch) window.__openSearch();
    });
  }

  var floatingTicking = false;
  window.addEventListener('scroll', function() {
    if (!floatingTicking) {
      requestAnimationFrame(function() {
        var show = window.scrollY > 300;
        if (searchBtnFloating) searchBtnFloating.classList.toggle('visible', show);
        if (backToTop) backToTop.classList.toggle('visible', show);
        floatingTicking = false;
      });
      floatingTicking = true;
    }
  }, { passive: true });

  if (backToTop) {
    backToTop.addEventListener('click', function() {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
