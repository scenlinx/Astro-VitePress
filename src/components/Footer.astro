---
// Footer.astro — 公共页脚组件
import { siteConfig } from '../config/site';
---
<footer class="footer">
  <p>{siteConfig.name} — {siteConfig.description}</p>
  <p class="footer-meta">
    <a href={siteConfig.github} target="_blank" rel="noopener">{siteConfig.name}</a>
    · 由 <a href={siteConfig.github} target="_blank" rel="noopener">{siteConfig.author}</a> 构建
    · {siteConfig.license}
  </p>
</footer>
