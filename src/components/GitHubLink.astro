---
// GitHubLink.astro — GitHub 链接按钮（导航栏和抽屉共用）
import GitHubIcon from './icons/GitHubIcon.astro';
import { siteConfig } from '../config/site';

export interface Props {
  showText?: boolean;
}

const { showText = false } = Astro.props;
---
<a href={siteConfig.github} class="nav-gh-link" target="_blank" rel="noopener" aria-label="GitHub">
  <GitHubIcon />
  {showText && 'GitHub'}
</a>
