---
// SearchModal.astro — 搜索弹窗组件（HTML + 客户端交互脚本）
import SearchIcon from './icons/SearchIcon.astro';
import { siteConfig } from '../config/site';

const searchIndexUrl = siteConfig.searchIndex;
---
<!-- Search modal -->
<div class="search-overlay" id="searchOverlay">
  <div class="search-modal">
    <div class="search-input-wrap">
      <span class="search-modal-icon">
        <SearchIcon />
      </span>
      <input type="text" class="search-input" id="searchInput" placeholder="搜索文档..." autofocus>
      <button class="search-close" id="searchClose">&times;</button>
    </div>
    <div class="search-results" id="searchResults"></div>
  </div>
</div>

<script define:vars={{ searchIndexUrl }}>
  let searchIndex = [];
  const searchOverlay = document.getElementById('searchOverlay');
  const searchInput = document.getElementById('searchInput');
  const searchResults = document.getElementById('searchResults');
  const searchClose = document.getElementById('searchClose');

  function highlight(text, query) {
    if (!text) return '';
    var idx = text.toLowerCase().indexOf(query);
    if (idx === -1) return text;
    return text.slice(0, idx) + '<mark>' + text.slice(idx, idx + query.length) + '</mark>' + text.slice(idx + query.length);
  }

  var searchLoading = false;

  function doSearch() {
    var q = (searchInput && searchInput.value || '').trim().toLowerCase();
    if (!q || searchIndex.length === 0) {
      if (searchResults) searchResults.innerHTML = '';
      return;
    }
    var matches = searchIndex.filter(function(item) {
      return item.title.toLowerCase().indexOf(q) !== -1 ||
        item.description.toLowerCase().indexOf(q) !== -1 ||
        item.content.toLowerCase().indexOf(q) !== -1;
    }).slice(0, 10);
    if (searchResults) {
      searchResults.innerHTML = matches.map(function(item) {
        return '<a href="' + item.url + '" class="search-result-item" onclick="document.getElementById(\'searchOverlay\').classList.remove(\'open\')">' +
          '<span class="search-result-title">' + highlight(item.title, q) + '</span>' +
          '<span class="search-result-desc">' + highlight(item.description, q) + '</span>' +
        '</a>';
      }).join('') || '<div class="search-result-empty">未找到相关结果</div>';
    }
  }

  window.__openSearch = function() {
    if (!searchOverlay) return;
    searchOverlay.classList.add('open');
    if (searchInput) searchInput.focus();
    if (searchIndex.length === 0 && !searchLoading) {
      searchLoading = true;
      fetch(searchIndexUrl)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          searchIndex = data;
          searchLoading = false;
          doSearch();
        })
        .catch(function() { searchLoading = false; });
    }
  };

  window.__closeSearch = function() {
    if (searchOverlay) searchOverlay.classList.remove('open');
    if (searchInput) searchInput.value = '';
    if (searchResults) searchResults.innerHTML = '';
  };

  if (searchClose) searchClose.addEventListener('click', window.__closeSearch);
  if (searchOverlay) searchOverlay.addEventListener('click', function(e) {
    if (e.target === searchOverlay) window.__closeSearch();
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') window.__closeSearch();
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      if (searchOverlay && searchOverlay.classList.contains('open')) {
        window.__closeSearch();
      } else {
        window.__openSearch();
      }
    }
  });

  if (searchInput) searchInput.addEventListener('input', doSearch);
</script>
