---
// SearchModal.astro — 搜索弹窗组件（HTML + 客户端交互脚本）
import SearchIcon from './icons/SearchIcon.astro';
---
<!-- Search modal -->
<div class="search-overlay" id="searchOverlay">
  <div class="search-modal">
    <div class="search-input-wrap">
      <span class="search-modal-icon">
        <SearchIcon />
      </span>
      <input type="text" class="search-input" id="searchInput" placeholder="搜索文档..." autofocus>
      <button class="search-close" id="searchClose">&times;</button>
    </div>
    <div class="search-results" id="searchResults"></div>
  </div>
</div>

<script>
  let searchIndex: any[] = [];
  const searchOverlay = document.getElementById('searchOverlay');
  const searchInput = document.getElementById('searchInput') as HTMLInputElement | null;
  const searchResults = document.getElementById('searchResults');
  const searchClose = document.getElementById('searchClose');

  function highlight(text: string, query: string): string {
    if (!text) return '';
    const idx = text.toLowerCase().indexOf(query);
    if (idx === -1) return text;
    return text.slice(0, idx) + '<mark>' + text.slice(idx, idx + query.length) + '</mark>' + text.slice(idx + query.length);
  }

  (window as any).__openSearch = () => {
    if (!searchOverlay) return;
    searchOverlay.classList.add('open');
    searchInput?.focus();
    if (searchIndex.length === 0) {
      fetch('/search.json')
        .then(r => r.json())
        .then((data: any[]) => { searchIndex = data; })
        .catch(() => {});
    }
  };

  (window as any).__closeSearch = () => {
    searchOverlay?.classList.remove('open');
    if (searchInput) searchInput.value = '';
    if (searchResults) searchResults.innerHTML = '';
  };

  searchClose?.addEventListener('click', (window as any).__closeSearch);
  searchOverlay?.addEventListener('click', (e) => {
    if (e.target === searchOverlay) (window as any).__closeSearch();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') (window as any).__closeSearch();
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      if (searchOverlay?.classList.contains('open')) {
        (window as any).__closeSearch();
      } else {
        (window as any).__openSearch();
      }
    }
  });

  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.trim().toLowerCase();
    if (!q || searchIndex.length === 0) {
      if (searchResults) searchResults.innerHTML = '';
      return;
    }
    const matches = searchIndex.filter((item: any) =>
      item.title.toLowerCase().includes(q) ||
      item.description.toLowerCase().includes(q) ||
      item.content.toLowerCase().includes(q)
    ).slice(0, 10);
    if (searchResults) {
      searchResults.innerHTML = matches.map((item: any) =>
        `<a href="${item.url}" class="search-result-item" onclick="document.getElementById('searchOverlay')?.classList.remove('open')">
          <span class="search-result-title">${highlight(item.title, q)}</span>
          <span class="search-result-desc">${highlight(item.description, q)}</span>
        </a>`
      ).join('') || '<div class="search-result-empty">未找到相关结果</div>';
    }
  });
</script>
