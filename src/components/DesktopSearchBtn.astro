---
// DesktopSearchBtn.astro — 桌面端搜索按钮（导航栏中）
import SearchIcon from './icons/SearchIcon.astro';
---
<button class="search-btn" id="desktopSearchBtn" aria-label="Search">
  <SearchIcon />
  <span class="search-btn-text">搜索</span>
  <span class="search-btn-hint">Ctrl K</span>
</button>

<script>
  document.getElementById('desktopSearchBtn')?.addEventListener('click', () => {
    (window as any).__openSearch?.();
  });
</script>
