---
interface Props {
  title: string;
  navItems?: { text: string; link: string }[];
  sidebarItems?: { text: string; link: string }[];
}

const { title, navItems = [], sidebarItems = [] } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} | VitePress</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="nav">
    <div class="nav-container">
      <a href="/" class="nav-logo">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span>VitePress</span>
      </a>
      <div class="nav-links">
        {navItems.map(item => (
          <a 
            href={item.link} 
            class={`nav-link ${currentPath === item.link ? 'active' : ''}`}
          >
            {item.text}
          </a>
        ))}
      </div>
      <button class="theme-toggle" aria-label="Toggle theme">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
      </button>
    </div>
  </nav>

  <div class="container">
    <aside class="sidebar sidebar-left">
      <div class="sidebar-header">
        <span>Menu</span>
      </div>
      <div class="sidebar-links">
        {sidebarItems.map(item => (
          <a 
            href={item.link} 
            class={`sidebar-link ${currentPath === item.link ? 'active' : ''}`}
          >
            {item.text}
          </a>
        ))}
      </div>
    </aside>

    <main class="main">
      <slot />
    </main>

    <aside class="sidebar sidebar-right">
      <div class="sidebar-header">
        <span>On this page</span>
      </div>
      <nav class="toc-links" id="toc-nav">
        <ul class="toc-list"></ul>
      </nav>
    </aside>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const headings = document.querySelectorAll('main h1, main h2, main h3');
      const tocList = document.querySelector('.toc-list');
      
      if (headings.length === 0 || !tocList) return;
      
      headings.forEach((heading, index) => {
        const id = `heading-${index}`;
        heading.id = id;
        
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = `#${id}`;
        a.textContent = heading.textContent;
        a.className = `toc-link toc-level-${heading.tagName.toLowerCase()}`;
        li.appendChild(a);
        tocList.appendChild(li);
      });

      const tocLinks = document.querySelectorAll('.toc-link');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          const id = entry.target.id;
          const link = document.querySelector(`.toc-link[href="#${id}"]`);
          if (link) {
            tocLinks.forEach(l => l.classList.remove('active'));
            link.classList.add('active');
          }
        });
      }, { rootMargin: '-20% 0% -35% 0%' });

      headings.forEach(h => observer.observe(h));
    });
  </script>

  <footer class="footer">
    <p>Powered by VitePress</p>
  </footer>
</body>
</html>
