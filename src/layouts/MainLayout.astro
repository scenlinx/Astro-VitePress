---
import SEOMeta from '../components/SEOMeta.astro';
import ThemeInit from '../components/ThemeInit.astro';
import NavBar from '../components/NavBar.astro';
import NavDrawer from '../components/NavDrawer.astro';
import Footer from '../components/Footer.astro';
import FloatingButtons from '../components/FloatingButtons.astro';
import SearchModal from '../components/SearchModal.astro';
import ThemeScript from '../components/ThemeScript.astro';
import { siteConfig } from '../config/site';
import '../styles/global.css';

interface Props {
  title?: string;
  frontmatter?: { title?: string; description?: string; keywords?: string; date?: string };
  navItems?: { text: string; link: string }[];
  sidebarItems?: { text: string; link: string }[];
  prev?: { text: string; link: string } | null;
  next?: { text: string; link: string } | null;
  slug?: string;
  currentSection?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title: propTitle, frontmatter, navItems = [], sidebarItems = [], prev, next, slug, currentSection, headings = [] } = Astro.props;
const title = propTitle || frontmatter?.title || siteConfig.name;
const desc = frontmatter?.description || siteConfig.description;
const kw = frontmatter?.keywords || siteConfig.keywords;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

const breadcrumbJson = slug && slug !== 'index' ? (() => {
  const segments = slug.split('/');
  const items = [
    { "@type": "ListItem", "position": 1, "name": "首页", "item": siteConfig.url }
  ];
  segments.forEach((seg, i) => {
    const path = '/' + segments.slice(0, i + 1).join('/');
    const name = i === segments.length - 1
      ? (frontmatter?.title || seg)
      : (currentSection || seg);
    items.push({
      "@type": "ListItem",
      "position": i + 2,
      "name": name,
      "item": `${siteConfig.url}${path}`
    });
  });
  return JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": items
  });
})() : '';
---

<!DOCTYPE html>
<html lang={siteConfig.lang}>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <ThemeInit />
  <SEOMeta 
    title={title}
    description={desc}
    keywords={kw}
    type="article"
    url={`${siteConfig.url}${currentPath}`}
    date={frontmatter?.date}
    jsonLdType="Article"
  />
  <link rel="icon" type="image/svg+xml" href={siteConfig.favicon}>
  <link rel="apple-touch-icon" href={siteConfig.appleTouchIcon}>
  <title>{title} | {siteConfig.name}</title>
  
  <!-- 页面关系 -->
  {prev && <link rel="prev" href={prev.link}>}
  {next && <link rel="next" href={next.link}>}

  {breadcrumbJson && <script type="application/ld+json" set:html={breadcrumbJson}></script>}
</head>
<body>
  <NavBar navItems={navItems} currentPath={currentPath} />

  <div class="sidebar-bg"></div>
  <div class="sidebar-overlay"></div>

  <nav class="sub-nav">
    <button class="sub-nav-left">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="sub-nav-icon">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
      <span>{currentSection || '文档'}</span>
    </button>
  </nav>

  <div class="container">
    <aside class="sidebar sidebar-left">
      <div class="sidebar-links">
        {sidebarItems.map(item => (
          <a 
            href={item.link} 
            class:list={['sidebar-link', { active: currentPath === item.link }]}
            aria-current={currentPath === item.link ? 'page' : undefined}
          >
            {item.text}
          </a>
        ))}
      </div>
    </aside>

    <main class="main">
      <slot />
      
      {frontmatter?.date && (
        <p class="page-date">更新于: {frontmatter.date}</p>
      )}
      
      <div class="prev-next">
        <div class="prev-next-item">
          {prev && (
            <a href={prev.link} class="prev-next-link">
              <span class="prev-next-label">← 上一页</span>
              <span class="prev-next-title">{prev.text}</span>
            </a>
          )}
        </div>
        <div class="prev-next-item prev-next-right">
          {next && (
            <a href={next.link} class="prev-next-link">
              <span class="prev-next-label">下一页 →</span>
              <span class="prev-next-title">{next.text}</span>
            </a>
          )}
        </div>
      </div>
      
      <Footer />
    </main>

    <aside class="sidebar sidebar-right">
      <div class="sidebar-header">
        <span>文章目录</span>
      </div>
      <nav class="toc-links" id="toc-nav">
        <ul class="toc-list">
          {headings.filter(h => h.depth === 2 || h.depth === 3).map(h => (
            <li>
              <a href={`#${h.slug}`} class={`toc-link toc-level-h${h.depth}`}>{h.text}</a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  </div>

  <NavDrawer navItems={navItems} currentPath={currentPath} />

  <FloatingButtons showBackToTop={true} />
  <SearchModal />
  <ThemeScript />

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const tocLinks = document.querySelectorAll('.toc-link');
      const headings = document.querySelectorAll('main h2, main h3');
      if (tocLinks.length === 0 || headings.length === 0) return;

      const setActive = (link: Element | null) => {
        tocLinks.forEach(l => l.classList.remove('active'));
        if (link) link.classList.add('active');
      };

      let clickPending = false;
      tocLinks.forEach(link => {
        link.addEventListener('click', e => {
          e.preventDefault();
          setActive(link);
          clickPending = true;
          setTimeout(() => { clickPending = false; }, 400);
          const target = document.querySelector(link.getAttribute('href') || '');
          if (target) {
            const top = target.getBoundingClientRect().top + window.scrollY - 80;
            window.scrollTo({ top, behavior: 'auto' });
          }
        });
      });

      // IntersectionObserver for TOC scrollspy
      const observer = new IntersectionObserver(entries => {
        if (clickPending) return;
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const idx = Array.from(headings).indexOf(entry.target as Element);
            if (tocLinks[idx]) setActive(tocLinks[idx]);
            break;
          }
        }
      }, { rootMargin: '-80px 0px -80% 0px' });
      headings.forEach(h => observer.observe(h));

      // Sub-nav sidebar trigger
      const sidebar = document.querySelector('.sidebar-left');
      const subNavLeft = document.querySelector('.sub-nav-left');
      const sidebarOverlay = document.querySelector('.sidebar-overlay');

      function openSidebar() {
        sidebar?.classList.add('open');
        sidebarOverlay?.classList.add('open');
      }

      function closeSidebar() {
        sidebar?.classList.remove('open');
        sidebarOverlay?.classList.remove('open');
      }

      subNavLeft?.addEventListener('click', () => {
        sidebar?.classList.contains('open') ? closeSidebar() : openSidebar();
      });

      sidebarOverlay?.addEventListener('click', closeSidebar);
    });

    ;(function() {
      var pres = document.querySelectorAll('.main pre');
      pres.forEach(function(pre) {
        var btn = document.createElement('button');
        btn.className = 'copy-btn';
        btn.textContent = '复制';
        btn.addEventListener('click', function() {
          var code = pre.querySelector('code');
          var text = code ? code.textContent || '' : pre.textContent || '';
          navigator.clipboard.writeText(text).then(function() {
            btn.textContent = '已复制!';
            setTimeout(function() { btn.textContent = '复制'; }, 2000);
          });
        });
        pre.style.position = 'relative';
        pre.appendChild(btn);
      });
    })();
  </script>
</body>
</html>
