---
interface Props {
  title?: string;
  frontmatter?: { title?: string; description?: string; keywords?: string; date?: string };
  navItems?: { text: string; link: string }[];
  sidebarItems?: { text: string; link: string }[];
  prev?: { text: string; link: string } | null;
  next?: { text: string; link: string } | null;
}

const { title: propTitle, frontmatter, navItems = [], sidebarItems = [], prev, next } = Astro.props;
const title = propTitle || frontmatter?.title || 'VitePress';
const desc = frontmatter?.description || 'VitePress 文档 - Vue 驱动的静态网站生成器';
const kw = frontmatter?.keywords || 'VitePress, Vue, 静态网站, 文档, 指南, 配置';
const currentPath = Astro.url.pathname;
const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "description": desc,
  "inLanguage": "zh-CN",
  "isPartOf": {
    "@type": "WebSite",
    "name": "VitePress",
    "url": "https://vitepress.vuejs.org"
  }
});
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={desc}>
  <meta name="keywords" content={kw}>
  <meta name="author" content="VitePress Team">
  
  <!-- Open Graph -->
  <meta property="og:title" content={`${title} | VitePress`}>
  <meta property="og:description" content={desc}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={`https://vitepress.vuejs.org${currentPath}`}>
  <link rel="canonical" href={`https://vitepress.vuejs.org${currentPath}`}>
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content={`${title} | VitePress`}>
  <meta name="twitter:description" content={desc}>
  
  <!-- JSON-LD -->
  <script type="application/ld+json" set:html={jsonLd}></script>
  
  <title>{title} | VitePress</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="nav">
    <div class="nav-container">
      <div class="nav-left">
        <a href="/" class="nav-logo">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>VitePress</span>
        </a>
      </div>
      <div class="nav-right">
        <div class="nav-links">
          {navItems.map(item => (
            <a 
              href={item.link} 
              class={`nav-link ${currentPath === item.link ? 'active' : ''}`}
            >
              {item.text}
            </a>
          ))}
        </div>
        <button class="theme-toggle" aria-label="Toggle theme">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <div class="sidebar-bg"></div>

  <div class="container">
    <aside class="sidebar sidebar-left">
      <div class="sidebar-header">
      </div>
      <div class="sidebar-links">
        {sidebarItems.map(item => (
          <a 
            href={item.link} 
            class={`sidebar-link ${currentPath === item.link ? 'active' : ''}`}
          >
            {item.text}
          </a>
        ))}
      </div>
    </aside>

    <main class="main">
      <slot />
      
      <div class="prev-next">
        <div class="prev-next-item">
          {prev && (
            <a href={prev.link} class="prev-next-link">
              <span class="prev-next-label">← 上一页</span>
              <span class="prev-next-title">{prev.text}</span>
            </a>
          )}
        </div>
        <div class="prev-next-item prev-next-right">
          {next && (
            <a href={next.link} class="prev-next-link">
              <span class="prev-next-label">下一页 →</span>
              <span class="prev-next-title">{next.text}</span>
            </a>
          )}
        </div>
      </div>
      
      <footer class="footer">
        <p>由 VitePress 驱动</p>
      </footer>
    </main>

    <aside class="sidebar sidebar-right">
      <div class="sidebar-header">
        <span>文章目录</span>
      </div>
      <nav class="toc-links" id="toc-nav">
        <ul class="toc-list"></ul>
      </nav>
    </aside>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const headings = document.querySelectorAll('main h2, main h3');
      const tocList = document.querySelector('.toc-list');
      
      if (headings.length === 0 || !tocList) return;
      
      headings.forEach(heading => {
        const id = heading.id || heading.textContent?.toLowerCase().replace(/\s+/g, '-').replace(/[^\w\u4e00-\u9fff-]/g, '');
        if (!heading.id) heading.id = id;
        
        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = `#${id}`;
        a.textContent = heading.textContent;
        a.className = `toc-link toc-level-${heading.tagName.toLowerCase()}`;
        li.appendChild(a);
        tocList.appendChild(li);
      });

      const tocLinks = document.querySelectorAll('.toc-link');
      const setActive = link => {
        tocLinks.forEach(l => l.classList.remove('active'));
        if (link) link.classList.add('active');
      };
      let clickPending = false;
      tocLinks.forEach(link => {
        link.addEventListener('click', e => {
          e.preventDefault();
          setActive(link);
          clickPending = true;
          const target = document.querySelector(link.getAttribute('href'));
          if (target) {
            const top = target.getBoundingClientRect().top + window.scrollY - 80;
            window.scrollTo({ top, behavior: 'auto' });
          }
        });
      });
      const updateActive = () => {
        if (clickPending) { clickPending = false; return; }
        const off = 80;
        let active = tocLinks[0];
        headings.forEach((h, i) => {
          if (h.getBoundingClientRect().top <= off) active = tocLinks[i];
        });
        setActive(active);
      };
      document.addEventListener('scroll', updateActive, { passive: true });
      updateActive();
    });

    const themeToggle = document.querySelector('.theme-toggle');
    const html = document.documentElement;
    
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme) {
      html.classList.add(savedTheme);
    } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
      html.classList.add('dark');
    }
    
    themeToggle?.addEventListener('click', () => {
      html.classList.toggle('dark');
      localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : '');
    });
  </script>
</body>
</html>
