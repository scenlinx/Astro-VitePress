---
import SEOMeta from '../components/SEOMeta.astro';
import NavBar from '../components/NavBar.astro';
import NavDrawer from '../components/NavDrawer.astro';
import Footer from '../components/Footer.astro';
import FloatingButtons from '../components/FloatingButtons.astro';
import SearchModal from '../components/SearchModal.astro';
import ThemeScript from '../components/ThemeScript.astro';
import { siteConfig } from '../config/site';

interface Props {
  title: string;
  description?: string;
  keywords?: string;
  navItems?: { text: string; link: string }[];
}

const { title, description = siteConfig.description, keywords = siteConfig.keywords, navItems = [] } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <SEOMeta 
    title={title}
    description={description}
    keywords={keywords}
    type="website"
    url={siteConfig.url}
    jsonLdType="WebSite"
  />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="apple-touch-icon" href="/apple-touch-icon.svg">
  <title>{title} | {siteConfig.name}</title>
  <link rel="stylesheet" href="/style.css">
  {navItems.length > 0 && navItems[0].link !== '/' && (
    <link rel="prefetch" href={navItems[0].link}>
  )}
</head>
<body class="home-page">
  <NavBar navItems={navItems} currentPath={currentPath} />
  <NavDrawer navItems={navItems} currentPath={currentPath} />
  <div class="sidebar-overlay"></div>

  <main class="main home-main">
    <slot />
  </main>

  <Footer />

  <FloatingButtons />
  <SearchModal />
  <ThemeScript />

  <script>
    let ticking = false;
    const nav = document.querySelector('.nav');
    const searchBtnFloating = document.getElementById('searchBtnFloating');
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrolled = window.scrollY > 0;
          const showFloating = window.scrollY > 300;
          nav?.classList.toggle('scrolled', scrolled);
          searchBtnFloating?.classList.toggle('visible', showFloating);
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  </script>
</body>
</html>
